# ============================================
# AI Knowledge Copilot - Environment Configuration
# ============================================

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_PROVIDER=openai  # openai | anthropic | local
LLM_MODEL=gpt-4o  # gpt-4o | claude-3-sonnet | local

# Embedding Configuration
EMBEDDING_PROVIDER=sentence-transformers  # openai | sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector Database
VECTOR_DB_TYPE=faiss  # faiss | pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=knowledge-copilot

# Database
DATABASE_URL=sqlite:///./data/knowledge_copilot.db

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEY_HEADER=X-API-Key

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
SEMANTIC_CHUNKING=true

# Retrieval Configuration
TOP_K_RESULTS=10
RERANK_TOP_K=5
HYBRID_SEARCH_ALPHA=0.7  # Weight for vector search (1-alpha for BM25)

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
